##############################################################################
#
#   Gradle start up script for POSIX generated by Gradle.
#
#   Important for running:
#
#   (1) You need a POSIX-compliant shell to run this script. If your /bin/sh is
#       noncompliant, but you have some other compliant shell such as ksh or
#       bash, then to run this script, type that shell name before the whole
#       command line, like:
#
#           ksh gradle
#
#       Busybox and similar reduced shells will NOT work, because this script
#       requires all of these POSIX shell features:
#         * functions;
#         * expansions «$var», «${var}», «${var:-default}», «${var+SET}»,
#           «${var#prefix}», «${var%suffix}», and «$( cmd )»;
#         * compound commands having a testable exit status, especially «case»;
#         * various built-in commands including «command», «set», and «ulimit».
#
#   Important for patching:
#
#   (2) This script targets any POSIX shell, so it avoids extensions provided
#       by Bash, Ksh, etc; in particular arrays are avoided.
#
#       The "traditional" practice of packing multiple parameters into a
#       space-separated string is a well documented source of bugs and security
#       problems, so this is (mostly) avoided, by progressively accumulating
#       options in "$@", and eventually passing that to Java.
#
#       Where the inherited environment variables (DEFAULT_JVM_OPTS, JAVA_OPTS,
#       and GRADLE_OPTS) rely on word-splitting, this is performed explicitly;
#       see the in-line comments for details.
#
#       There are tweaks for specific operating systems such as AIX, CygWin,
#       Darwin, MinGW, and NonStop.
#
#   (3) This script is generated from the Groovy template
#       https://github.com/gradle/gradle/blob/8.8/subprojects/plugins/src/main/resources/org/gradle/api/internal/plugins/unixStartScript.txt
#       within the Gradle project.
#
#       You can find Gradle at https://github.com/gradle/gradle/.
#
##############################################################################

# Attempt to set APP_HOME

# Resolve links: $0 may be a link
app_path=$0

# Need this for daisy-chained symlinks.
while
    APP_HOME=${app_path%"${app_path##*/}"}  # leaves a trailing /; empty if no leading path
    [ -h "$app_path" ]
do
    ls=$( ls -ld "$app_path" )
    link=${ls#*' -> '}
    case $link in             #(
      /*)   app_path=$link ;; #(
      *)    app_path=$APP_HOME$link ;;
    esac
done

# This is normally unused
# shellcheck disable=SC2034
APP_BASE_NAME=${app_path##*/}
# Discard cd standard output in case $CDPATH is set https://github.com/gradle/gradle/issues/25036
APP_HOME=$( cd "${APP_HOME:-./}" > /dev/null && pwd -P ) || exit

# Use the maximum available, or set MAX_FD != -1 to use that value.
MAX_FD=maximum

warn () {
    echo "$*"
} >&2

die () {
    echo
    echo "$*"
    echo
    exit 1
} >&2

# OS specific support (must be 'true' or 'false').
cygwin=false
msys=false
darwin=false
nonstop=false
case "$( uname )" in                #(
  CYGWIN* )         cygwin=true  ;; #(
  Darwin* )         darwin=true  ;; #(
  MSYS* | MINGW* )  msys=true    ;; #(
  NONSTOP* )        nonstop=true ;;
esac

CLASSPATH=$APP_HOME/gradle/wrapper/gradle-wrapper.jar


# Determine the Java command to use to start the JVM.
if [ -n "$JAVA_HOME" ] ; then
    if [ -x "$JAVA_HOME/jre/sh/java" ] ; then
        # IBM's JDK on AIX uses strange locations for the executables
        JAVACMD=$JAVA_HOME/jre/sh/java
    else
        JAVACMD=$JAVA_HOME/bin/java
    fi
    if [ ! -x "$JAVACMD" ] ; then
        die "ERROR: JAVA_HOME is set to an invalid directory: $JAVA_HOME

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
    fi
else
    JAVACMD=java
    if ! command -v java >/dev/null 2>&1
    then
        die "ERROR: JAVA_HOME is not set and no 'java' command could be found in your PATH.

Please set the JAVA_HOME variable in your environment to match the
location of your Java installation."
    fi
fi

# Increase the maximum file descriptors if we can.
if ! "$cygwin" && ! "$darwin" && ! "$nonstop" ; then
    case $MAX_FD in #(
      max*)
        # In POSIX sh, ulimit -H is undefined. That's why the result is checked to see if it worked.
        # shellcheck disable=SC2039,SC3045
        MAX_FD=$( ulimit -H -n ) ||
            warn "Could not query maximum file descriptor limit"
    esac
    case $MAX_FD in  #(
      '' | soft) :;; #(
      *)
        # In POSIX sh, ulimit -n is undefined. That's why the result is checked to see if it worked.
        # shellcheck disable=SC2039,SC3045
        ulimit -n "$MAX_FD" ||
            warn "Could not set maximum file descriptor limit to $MAX_FD"
    esac
fi

# Collect all arguments for the java command, stacking in reverse order to eventually pass to java.
# We stack in reverse order to handle arguments that might contain spaces within.

# Default JVM options used for java execution.
DEFAULT_JVM_OPTS='"-Xmx64m" "-Xms64m"'

# Collect all arguments that start with a dash, and maybe also the classpath and the main class.
# At the end of this loop, "args" contains all dash-starting arguments (if any), and "non_dash_args" contains the rest.
# Then we choose between using the argument list (dash and non-dash) as a single string (for a simple command), or
# keeping them separate (for the "exec" command, where argument list expansion may be desirable).
# We also specifically handle the "classpath" and "classpath" arguments, because they have special meaning in exec,
# but only if they are terminated and not part of a previous argument that might have embedded spaces.

# The "split" and "shell" arguments to java are handled later by the arg walk.

# We use a while loop to remove quotes from certain arguments, because shell interpolation
# can't be used here, because we need to keep arguments with embedded quotes together as
# a single string for later passing to java. Yes, it's more code, but it's necessary for
# proper argument handling across all combinations of shells and uses of the script.

# First, we prepare a temporary array for dash arguments, and a temporary array for non-dash arguments.
# We also prepare a variable for the classpath, and a variable for the main class, if specified.
# We will later combine them into the final command line.

dash_args=()
non_dash_args=()
classpath=()
main=()

# Default to using the main class specified, if any. If not, we will gather all non-dash arguments as the main class.
main_class=

# Parse all arguments, accumulating non-dash args to the main class (or to the exec call), and dash args to an array.
# We handle dash args of the form "--argument=value" by separating them into "--argument" and "value", and adding
# them to the dash array as separate entries. This preserves the ability to pass quoted values through.
# We also handle the classpath and main class specially, and we add the classpath to the classpath array,
# and the main class to the main array.

while [ $# -gt 0 ]
do
    arg="$1"
    shift

    # If the argument starts with a dash, it's a JVM/internal/dash argument. We'll add it to the dash array.
    # But first, we need to see if it has an equals sign.
    case "$arg" in
        --*=*)
            # Remove everything up to the first equals sign to get the key.
            key=${arg%%=*}
            # Remove the key and the equals sign to get the value.
            value=${arg#*=}
            # For certain keys, we handle specially.
            case "$key" in
                --classpath)
                    classpath+=("$value")
                    ;;
                --main-class)
                    main_class="$value"
                    main+=("$value")
                    ;;
                *)
                    # For other keys, we add to the dash array as two separate arguments.
                    dash_args+=("$key")
                    dash_args+=("$value")
                    ;;
            esac
            ;;
        --classpath)
            # Next argument is the classpath.
            classpath+=("$1")
            shift
            ;;
        --main-class)
            # Next argument is the main class.
            main_class="$1"
            main+=("$1")
            shift
            ;;
        -*)
            # Just a plain dash argument, add to dash array.
            dash_args+=("$arg")
            ;;
        *)
            # Not a dash argument, add to non_dash_args array.
            non_dash_args+=("$arg")
            ;;
    esac
done

# If we have a main class specified, we need to add all non-dash arguments to the main class arguments.
# Otherwise, we need to add all non-dash arguments as the main class.
if [ -n "$main_class" ]; then
    # We have a main class specified, so non_dash_args are arguments to the main class.
    main_args=("${non_dash_args[@]}")
else
    # No main class specified, so non_dash_args are the main class and its arguments.
    # The first non_dash_arg is the main class, the rest are arguments to it.
    if [ ${#non_dash_args[@]} -gt 0 ]; then
        main_class="${non_dash_args[0]}"
        main+=("${non_dash_args[0]}")
        main_args=("${non_dash_args[@]:1}")
    fi
fi

# Prepare the classpath for the java command.
# If classpath is empty, we don't add it. If it's not empty, we join with the path separator.
if [ ${#classpath[@]} -gt 0 ]; then
    CLASSPATH="${classpath[*]}"
    export CLASSPATH
fi

# Prepare the main class arguments.
if [ ${#main_args[@]} -gt 0 ]; then
    MAIN_CLASS_ARGS="${main_args[*]}"
else
    MAIN_CLASS_ARGS=""
fi

# Now we have all the information to build the final command line.
# We will use the following order:
# 1. The java command itself.
# 2. The default JVM options.
# 3. The JAVA_OPTS environment variable (if set).
# 4. The GRADLE_OPTS environment variable (if set).
# 5. Any dash arguments we've collected.
# 6. The classpath.
# 7. The main class.
# 8. The main class arguments.

# Build the command line.
cmd=("$JAVACMD")
if [ -n "$DEFAULT_JVM_OPTS" ]; then
    # We need to split the default JVM options into separate arguments.
    # In POSIX sh, we can't use arrays for this, but we can use word splitting.
    # We set IFS to space and use set -f to disable globbing.
    # We then use set -- to reset the arguments to the split words.
    OIFS=$IFS
    IFS=' '
    set -f
    set -- $DEFAULT_JVM_OPTS
    IFS=$OIFS
    set +f
    cmd+=("$@")
fi
if [ -n "$JAVA_OPTS" ]; then
    OIFS=$IFS
    IFS=' '
    set -f
    set -- $JAVA_OPTS
    IFS=$OIFS
    set +f
    cmd+=("$@")
fi
if [ -n "$GRADLE_OPTS" ]; then
    OIFS=$IFS
    IFS=' '
    set -f
    set -- $GRADLE_OPTS
    IFS=$OIFS
    set +f
    cmd+=("$@")
fi
if [ ${#dash_args[@]} -gt 0 ]; then
    cmd+=("${dash_args[@]}")
fi

# Add the classpath.
if [ -n "$CLASSPATH" ]; then
    cmd+=(-classpath "$CLASSPATH")
fi

# Add the main class.
if [ -n "$main_class" ]; then
    cmd+=("$main_class")
fi

# Add the main class arguments.
if [ -n "$MAIN_CLASS_ARGS" ]; then
    # We need to split the main class arguments into separate arguments.
    OIFS=$IFS
    IFS=' '
    set -f
    set -- $MAIN_CLASS_ARGS
    IFS=$OIFS
    set +f
    cmd+=("$@")
fi

# Execute the command.
exec "${cmd[@]}"